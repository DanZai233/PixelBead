# 浏览器本地 npm run dev：若要调用线上 /api，可任选其一（不要提交敏感信息到公开仓库）
# VITE_API_BASE_URL=https://你的域名
# VITE_AI_GENERATE_URL=https://你的域名
# iOS/Android 打包：务必在 .env.capacitor 中设置 VITE_API_BASE_URL（与 materialService 共用）

# 以下三项仅在 Vercel「服务端」环境变量中配置（勿使用 VITE_ 前缀，勿暴露给浏览器）
# PIXELBEAD_AI_API_KEY=
# PIXELBEAD_AI_API_BASE=（图像生成 HTTP API 根路径，部署时按你的服务商文档填写）
# PIXELBEAD_AI_IMAGE_MODEL=doubao-seedream-4-5-251128

# Upstash Redis（分享链接）
# VITE_UPSTASH_REDIS_REST_URL=
# VITE_UPSTASH_REDIS_REST_TOKEN=

# MongoDB（素材广场）
# MONGODB_URI=
