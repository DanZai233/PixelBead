   {
   "version": 2,
   "builds": [
     {
       "src": "package.json",
       "use": "@vercel/static-build",
       "config": {
         "distDir": "dist"
       }
     },
     {
       "src": "api/analytics.ts",
       "use": "@vercel/node"
     }
   ],
   "routes": [
     {
       "src": "/api/analytics",
       "dest": "/api/analytics.ts"
     },
     {
       "src": "/(.*)",
       "dest": "/$1"
     }
   ]
 }
